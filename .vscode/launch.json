    "version": "0.2.0",
    "configurations": [
    {
        "name": "C#: MemQuran-api${cwd} Debug",
        "type": "dotnet",
        "request": "attach",
        "projectPath": "${workspaceFolder}/src/MemQuran.Api.csproj"
    },
        {
            "name": ".NET Core Launch (web)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/src/MemQuran.Api/bin/Debug/net10.0/MemQuran.Api.dll",
            "args": [],
            "cwd": "${workspaceFolder}/src/MemQuran.Api",
            "stopAtEntry": false,
            "serverReadyAction": {
                // "action": "openExternally",
                // "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            },
            "sourceFileMap": {
                "/Views": "${workspaceFolder}/Views"
            }
        },
        {
            "name": ".NET Core Attach",
            "type": "coreclr",
            "request": "attach"
        }
    ]
}